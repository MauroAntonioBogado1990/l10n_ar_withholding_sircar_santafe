<?xml version='1.0' encoding='UTF-8'?>
<odoo>
   <data>

     <record id="view_account_export_santafe_form" model="ir.ui.view">
         <field name="name">account.export.santafe.form</field>
         <field name="model">account.export.santafe</field>
         <field name="arch" type="xml">
            <form>
                <header>
                    <button name="compute_santafe_data" string="Generar Santa Fe" type="object" />
                </header>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="date_from" />
                        <field name="date_to" />
                        <field name="tax_withholding" />
                    </group>
                    <notebook>

                        <!-- ── PERCEPCIONES ── -->
                        <page name="page_percepciones" string="Percepciones">
                            <group string="DATOSPERC.txt — Detalle de percepciones">
                                <field name="export_santafe_filename_per" invisible="1"/>
                                <field name="export_santafe_file_per" widget="binary"
                                       filename="export_santafe_filename_per"/>
                                <field name="export_santafe_data_per" readonly="1"/>
                            </group>
                            <group string="PERCECIONESRETPER.txt — Sujetos percibidos">
                                <field name="export_santafe_filename" invisible="1"/>
                                <field name="export_santafe_file" widget="binary"
                                       filename="export_santafe_filename"/>
                                <field name="export_santafe_data" readonly="1"/>
                            </group>
                            <group string="NCFACTPERC.txt — Notas de crédito">
                                <field name="export_santafe_filename_nc" invisible="1"/>
                                <field name="export_santafe_file_nc" widget="binary"
                                       filename="export_santafe_filename_nc"/>
                                <field name="export_santafe_data_nc" readonly="1"/>
                            </group>
                        </page>

                        <!-- ── RETENCIONES ── -->
                        <page name="page_retenciones" string="Retenciones">
                            <group string="DATOSRET.txt — Detalle de retenciones">
                                <field name="export_santafe_filename_ret" invisible="1"/>
                                <field name="export_santafe_file_ret" widget="binary"
                                       filename="export_santafe_filename_ret"/>
                                <field name="export_santafe_data_ret" readonly="1"/>
                            </group>
                            <group string="RETPER.txt — Sujetos retenidos">
                                <field name="export_santafe_filename_retper" invisible="1"/>
                                <field name="export_santafe_file_retper" widget="binary"
                                       filename="export_santafe_filename_retper"/>
                                <field name="export_santafe_data_retper" readonly="1"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
         </field>
    </record>
     
    <record id="view_account_export_santafe_list" model="ir.ui.view">
         <field name="name">account.export.santafe.list</field>
         <field name="model">account.export.santafe</field>
            <field name="arch" type="xml">
                <tree>
                     <field name="name" />
                     <field name="date_from" />
                     <field name="date_to" />
                </tree>
            </field>
    </record>



        <record id="action_account_export_santafe" model="ir.actions.act_window">
            <field name="name">Exportaciones de Santa Fe</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.export.santafe</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_account_export_santafe"
                  action="action_account_export_santafe"
                  parent="l10n_ar.account_reports_ar_statements_menu"
                  sequence="6"/>


       </data>
</odoo>
