<?xml version="1.0" encoding="utf-8"?>
<odoo>    
        <record id="view_partner_iibb_santafe_form" model="ir.ui.view">
            <field name="name">res.partner.form</field>
            <field name="model">res.partner</field>
            <!--aqui se tiene que cambiar la herencia cuando se va a instalar en enterprise-->
            <!--<field name="inherit_id" ref="l10n_ar_withholding.view_partner_property_form"/> -->
            <!-- <field name="inherit_id" ref="l10n_ar_partner.view_partner_property_form"/> -->
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <!-- <page name="fiscal_data" position="inside"> -->
                <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Per/Ret Santa Fe">
                
                    <h3 style="text-align: center;">Retenciones IIBB Santa Fe</h3>
                    <field name="alicuot_ret_santafe_ids">
                        <tree string="Retenciones IIBB Santa Fe" editable="bottom">
                            <field name="publication_date"/>
                            <field name="effective_date_from"/>
                            <field name="effective_date_to"/>
                            <field name="type_contr_insc"/>
                            <field name="alta_baja"/>
                            <field name="cambio"/>
                            <field name="a_ret"/>
                            <field name="nro_grupo_ret"/>
                            <field name="coeficiente"/> <!--se agrego el campo coeficiente-->
                        </tree>
                    </field>
                    <h3 style="text-align: center;">Percepciones IIBB Santa Fe</h3>
                    <field name="alicuot_per_santafe_ids">
                        <tree string="Percepciones IIBB Santa Fe" editable="bottom">
                            <field name="publication_date"/>
                            <field name="effective_date_from"/>
                            <field name="effective_date_to"/>
                            <field name="type_contr_insc"/>
                            <field name="alta_baja"/>
                            <field name="cambio"/>
                            <field name="a_per"/>
                            <field name="nro_grupo_per"/>
                            <field name="coeficiente"/> <!--se agrego el campo coeficiente-->
                        </tree>
                    </field>
                </page>
               </xpath>
            </field>
    </record>

</odoo>
